<!--
  Moodle Block Plugin v6
  V2 style — Learning Tools as card grid (not list)
  No notification center
-->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Fredoka+One&display=swap"
    rel="stylesheet">

<style>
    :root {
        --primary: #3B5BDB;
        --primary-dark: #2D46C5;
        --secondary: #0CA678;
        --bg-page: #F4F6FB;
        --bg-white: #FFFFFF;
        --text-heading: #1A1F36;
        --text-muted: #8492A6;
        --border: #E8EBF4;
        --shadow-sm: 0 2px 8px rgba(59, 91, 219, 0.08);
        --shadow-md: 0 4px 20px rgba(59, 91, 219, 0.12);
        --shadow-lg: 0 8px 32px rgba(59, 91, 219, 0.16);
        --r-sm: 10px;
        --r-md: 14px;
        --r-lg: 20px;
        --r-xl: 24px;
    }

    .block_pedago-pb6 * {
        box-sizing: border-box;
        font-family: 'Poppins', sans-serif;
    }

    /* ════════ BODY ════════ */
    .block_pedago-pb6-body {
        padding: 16px 16px 18px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    /* ── Section header ── */
    .block_pedago-sec-hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .block_pedago-sec-hdr-title {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-heading);
        text-transform: uppercase;
        letter-spacing: 0.7px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .block_pedago-sec-hdr-title .block_pedago-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        display: inline-block;
    }

    .block_pedago-sec-hdr-link {
        font-size: 11px;
        font-weight: 600;
        color: var(--primary);
        text-decoration: none;
        opacity: 0.8;
        transition: opacity 0.15s;
    }

    .block_pedago-sec-hdr-link:hover {
        opacity: 1;
    }

    /* ── Upcoming class ── */
    .block_pedago-upcoming-card {
        background: linear-gradient(135deg, #087F5B 0%, #0CA678 100%);
        border-radius: var(--r-md);
        padding: 12px 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        /* box-shadow: 0 4px 16px rgba(12, 166, 120, 0.25); */
        transition: transform 0.18s ease;
    }

    .block_pedago-upcoming-card:hover {
        transform: translateY(-2px);
    }

    .block_pedago-upcoming-icon {
        font-size: 26px;
        line-height: 1;
    }

    .block_pedago-upcoming-info {
        flex: 1;
    }

    .block_pedago-upcoming-label {
        color: rgba(255, 255, 255, 0.75);
        font-size: 9.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .block_pedago-upcoming-title {
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        margin: 1px 0 2px;
    }

    .block_pedago-upcoming-time {
        color: rgba(255, 255, 255, 0.80);
        font-size: 10.5px;
        font-weight: 500;
    }

    .block_pedago-upcoming-btn {
        background: rgba(255, 255, 255, 0.20);
        border: 1px solid rgba(255, 255, 255, 0.30);
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        padding: 5px 11px;
        border-radius: 20px;
        white-space: nowrap;
    }

    /* ── Quick Nav ── */
    .block_pedago-quick-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 9px;
    }

    .block_pedago-qnav-item {
        background: var(--bg-white);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 12px 8px 11px;
        text-align: center;
        text-decoration: none;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
        /* box-shadow: var(--shadow-sm); */
        display: block;
    }

    .block_pedago-qnav-item:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-sm);
    }

    .block_pedago-qnav-icon-wrap {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        margin: 0 auto 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 19px;
    }

    .block_pedago-qnav-label {
        font-size: 10.5px;
        font-weight: 700;
        color: var(--text-heading);
        line-height: 1.25;
    }

    .block_pedago-ic-blue {
        background: #EEF2FF;
    }

    .block_pedago-ic-teal {
        background: #E6FCF5;
    }

    .block_pedago-ic-orange {
        background: #FFF4E6;
    }

    .block_pedago-ic-pink {
        background: #FFF0F6;
    }

    .block_pedago-ic-yellow {
        background: #FFF9DB;
    }

    .block_pedago-ic-cyan {
        background: #E3FAFC;
    }

    .block_pedago-ic-violet {
        background: #F3F0FF;
    }

    /* ════════ LEARNING TOOLS — CARD GRID ════════ */
    .block_pedago-tools-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .block_pedago-tool-card {
        background: var(--bg-white);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        padding: 14px 14px 13px;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
        /* box-shadow: var(--shadow-sm); */
        position: relative;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .block_pedago-tool-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-sm);
    }


    .block_pedago-tool-card-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 6px;
    }

    .block_pedago-tool-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .block_pedago-tool-badge {
        font-size: 9.5px;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 20px;
        white-space: nowrap;
        align-self: flex-start;
    }

    .block_pedago-badge-orange {
        background: #FFF4E6;
        color: #E67700;
    }

    .block_pedago-badge-green {
        background: #E6FCF5;
        color: #0CA678;
    }

    .block_pedago-badge-red {
        background: #FFF5F5;
        color: #C92A2A;
    }

    .block_pedago-badge-blue {
        background: #EEF2FF;
        color: #3B5BDB;
    }

    .block_pedago-tool-body .block_pedago-tool-title {
        font-size: 12.5px;
        font-weight: 700;
        color: var(--text-heading);
        line-height: 1.3;
        margin: 0 0 2px;
    }

    .block_pedago-tool-body .block_pedago-tool-sub {
        font-size: 10.5px;
        font-weight: 500;
        color: var(--text-muted);
        margin: 0;
    }

    /* mini progress inside card */
    .block_pedago-tool-progress {
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .block_pedago-tool-progress .block_pedago-tp-bg {
        flex: 1;
        height: 5px;
        background: #E8EBF4;
        border-radius: 10px;
        overflow: hidden;
    }

    .block_pedago-tool-progress .block_pedago-tp-fill {
        height: 100%;
        border-radius: 10px;
    }

    .block_pedago-tool-progress .block_pedago-tp-pct {
        font-size: 9.5px;
        font-weight: 700;
        color: var(--text-muted);
    }
</style>

