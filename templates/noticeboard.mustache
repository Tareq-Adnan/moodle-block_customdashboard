}
}}

<div class="container mb-2">

    <div class="block_cudb-search-wrapper">
        <p class="text-center fw-bold mb-0">All your class announcements in one place</p>
        <div class="block_cudb-search-note">
            <i class="bi bi-info-circle"></i> Browse all class updates below
        </div>
    </div>

    <div class="block_cudb-count-badge">
        <i class="bi bi-megaphone"></i> All announcements
        <span class="block_cudb-count-number">{{activities.total}}</span>
    </div>

    <div class="block_cudb-notices-grid">
        {{#activities.notices}}
        <div class="block_cudb-notice-card">
            <div class="block_cudb-card-content">
                <div class="block_cudb-course-chip">{{course}}</div>
                <div class="block_cudb-discussion-title">{{discussion}}</div>
                <div class="block_cudb-forum-row">{{forum}}</div>
                <a href="{{url}}" class="hw-btn" target="_blank">View details</a>
            </div>
        </div>
        {{/activities.notices}}
    </div>
    {{^activities.notices}}
    <div class="block_cudb-notice-card p-3 text-center">No announcements or notices are published.</div>
    {{/activities.notices}}
</div>