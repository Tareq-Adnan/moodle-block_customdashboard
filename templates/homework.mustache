{{! Moodle Mustache Template — paste inside your plugins renderer }}
{{! Requires Bootstrap 4 (built into Moodle 3.x+) }}

<div class="hw-grid-wrap">

    {{#activities.has_needattention}}
    <p class="hw-section-label">
        <i class="fa fa-circle-exclamation me-1" style="color:#e65100;font-size:18px;"></i>
        Needs attention
    </p>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-3 mb-4">
    {{#activities.needattention}}
        <!-- Overdue card -->
        <div class="col">
            <div class="hw-card">
                <div class="d-flex align-items-center gap-2">
                    <div class="hw-icon icon-asgn"><img src="{{iconurl}}" alt="" width="18" height="18"></div>
                    <div class="overflow-hidden">
                        <p class="hw-course">{{coursetitle}}</p>
                        <p class="hw-title">{{activitytitle}}</p>
                    </div>
                </div>
                <hr class="hw-divider" />
                <div class="d-flex align-items-center justify-content-between my-2">
                    <span class="hw-due"><i class="fa fa-calendar-xmark"></i>
                        {{#duedate}}
                        {{duedate}}
                        {{/duedate}}</span>
                    <div class="d-flex align-items-center gap-2">
                        <!-- <span class="hw-pts">100 pts</span> -->
                        <span class="hw-badge badge-{{badgeclass}}">{{badgemsg}}</span>
                    </div>
                </div>
                <a href="{{activityurl}}" class="hw-btn hw-btn-{{badgeclass}}">
                    <i class="fa fa-arrow-up-from-bracket"></i> Submit now
                </a>
            </div>
        </div>
            {{/activities.needattention}}
    </div><!-- /needs attention row -->
    {{/activities.has_needattention}}

    <!-- ── SECTION: Upcoming ── -->
    {{#activities.has_upcoming}}
    <p class="hw-section-label">
        <i class="fa fa-calendar-days me-1" style="color:#1a73e8;font-size:18px;"></i>
        Upcoming
    </p>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-3 mb-4">
    {{#activities.upcoming}}
        <!-- Project card -->
        <div class="col">
            <div class="hw-card">
                <div class="d-flex align-items-center gap-2">
                    <div class="hw-icon icon-proj"><img src="{{iconurl}}" alt="" width="18" height="18"></div>
                    <div class="overflow-hidden">
                        <p class="hw-course">{{coursetitle}}</p>
                        <p class="hw-title">{{activitytitle}}</p>
                    </div>
                </div>
                <hr class="hw-divider" />
                <div class="d-flex align-items-center justify-content-between">
                    <span class="hw-due"><i class="fa fa-calendar"></i> {{duedate}}</span>
                    <div class="d-flex align-items-center gap-2">
                        <!-- <span class="hw-pts">200 pts</span> -->
                        <span class="hw-badge badge-{{badgeclass}}">{{badgemsg}}</span>
                    </div>
                </div>
                <a href="{{activityurl}}" class="hw-btn">
                    <i class="fa fa-arrow-up-from-bracket"></i> Submit work
                </a>
            </div>
        </div>
            {{/activities.upcoming}}
    </div><!-- /upcoming row -->
    {{/activities.has_upcoming}}

    <!-- ── SECTION: Completed ── -->
    {{#activities.has_completed}}
    <p class="hw-section-label">
        <i class="fa fa-circle-check me-1" style="color:#137333;font-size:18px;"></i>
        Completed
    </p>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-3">
        {{#activities.completed}}
        <!-- Graded card -->
        <div class="col">
            <div class="hw-card" style="opacity:.85;">
                <div class="d-flex align-items-center gap-2">
                    <div class="hw-icon icon-asgn"><img src="{{iconurl}}" alt="" width="18" height="18"></div>
                    <div class="overflow-hidden">
                        <p class="hw-course">{{coursetitle}}</p>
                        <p class="hw-title" style="text-decoration:line-through;color:#6c757d;">{{activitytitle}}</p>
                    </div>
                </div>
                <hr class="hw-divider" />
                <div class="d-flex align-items-center justify-content-between">
                    <span class="hw-due"><i class="fa fa-calendar-check"></i> {{duedata}}</span>
                    <div class="d-flex align-items-center gap-2">
                        <!-- <span class="hw-score">92/100</span> -->
                        <span class="hw-badge badge-done">Completed</span>
                    </div>
                </div>
                <a href="{{activityurl}}" class="hw-btn hw-btn-done">
                    <i class="fa fa-eye"></i> View feedback
                </a>
            </div>
        </div>
            {{/activities.completed}}
    </div><!-- /completed row -->
    {{/activities.has_completed}}
</div><!-- /hw-grid-wrap -->

{{^activities.has_needattention}}
{{^activities.has_upcoming}}
{{^activities.has_completed}}
<div class="col-12 w-100 text-center">
    <p class="text-muted text-center border p-3 rounded">No tasks are assigned</p>
</div>
{{/activities.has_completed}}
{{/activities.has_upcoming}}
{{/activities.has_needattention}}