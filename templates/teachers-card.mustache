{{!
@template block_customdashboard/teachers-card

Reusable teachers Card component.

Context variables required for this template:
* activities - Object with activities data
}}

<div class="activities-widget mb-4">

    <div class="card border-0">
        <div class="card-body p-3">

            {{#activities.hasitems}}
            <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-3 g-4">

                {{#activities.items}}
                <div class="col">
                    <div class="card teacher-card border rounded- overflow-hidden h-100 d-flex flex-column">

                        <!-- Cover -->
                        <div class="bg-primary-subtle" style="height: 70px;"></div>

                        <!-- Avatar -->
                        <div class="text-center position-relative" style="margin-top: -40px;">
                            <div class="overflow-hidden mx-auto">
                                {{{picture}}}
                            </div>
                        </div>

                        <!-- Body -->
                        <div class="card-body text-center pt-2 d-flex flex-column">

                            <!-- FLEX CONTENT -->
                            <div class="flex-grow-1">

                                <!-- Name -->
                                <h6 class="fw-semibold mb-1 teacher-name text-truncate">
                                    {{fullname}}
                                </h6>

                                <!-- Email -->
                                <small class="text-muted d-block text-truncate mb-1">
                                    <i class="bi bi-envelope-fill me-1"></i>{{email}}
                                </small>

                                <!-- Phone -->
                                {{#hasphone}}
                                <small class="text-muted d-block mb-2">
                                    <i class="bi bi-telephone-fill me-1"></i>{{phone}}
                                </small>
                                {{/hasphone}}

                                <hr class="my-2">

                                <!-- Courses -->
                                <div class="mb-3 small text-muted course-text">
                                    <i class="bi bi-book me-1"></i>
                                    {{courseslist}}
                                </div>

                            </div>

                            <!-- ACTION BUTTONS (ALWAYS BOTTOM) -->
                            <div class="d-flex justify-content-center gap-2 mt-auto">

                                <a href="mailto:{{email}}"
                                   class="btn btn-outline-secondary btn-sm rounded-pill px-4">
                                    <i class="bi bi-envelope me-1"></i>Email
                                </a>

                                <a href=""
                                   class="btn-msg btn btn-outline-secondary btn-sm rounded-pill px-3">
                                    <i class="bi bi-chat me-1"></i>Message
                                </a>

                            </div>

                        </div>
                    </div>
                </div>
                {{/activities.items}}

            </div>
            {{/activities.hasitems}}

            {{^activities.hasitems}}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-person-x fs-1"></i>
                <p class="mt-2 mb-0">
                    {{#str}}noactivities, block_customdashboard{{/str}}
                </p>
            </div>
            {{/activities.hasitems}}

        </div>
    </div>

</div>
{{#js}}
let msgs = document.querySelectorAll('.btn-msg');

if (msgs.length) {
    msgs.forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();

            let card = btn.closest('.teacher-card');
            if (!card) return;

            let nameEl = card.querySelector('.teacher-name');
            if (!nameEl) return;

            let name = nameEl.textContent.trim();

            let toggle = document.querySelector('[data-region="popover-region-messages"] .popover-region-toggle');
            if (!toggle) return;

            toggle.click();

            let searchBox = document.querySelector('input[data-region="view-overview-search-input"]');
            let searchBox2 = document.querySelector('input[data-region="search-input"]');
            let button = document.querySelector('button[data-action="search"]');

            if (searchBox) {
                searchBox.focus();
                searchBox.click();
                searchBox2.value = name;
                searchBox2.dispatchEvent(new Event('input', { bubbles: true }));
                button.click();
                const container = document.querySelector('[data-region="non-contacts-container"]');

                if (!container) return;

                const observer = new MutationObserver(() => {
                    let contact = container.querySelector('a[data-route="view-conversation"]');

                    if (contact) {
                        console.log(contact);
                        contact.click();
                        observer.disconnect();
                    }
                });

                observer.observe(container, {
                    childList: true,
                    subtree: true
                });
            }
        });
    });
}
{{/js}}